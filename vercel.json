{
  "rewrites": [
    { "source": "/", "destination": "/login.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/inbox", "destination": "/inbox.html" },
    { "source": "/compose", "destination": "/compose.html" },
    { "source": "/sent", "destination": "/sent.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/view_message/:id", "destination": "/view_message.html" },
    { "source": "/css/(.*)", "destination": "/css/$1" },
    { "source": "/js/(.*)", "destination": "/js/$1" },
    { "source": "/assets/(.*)", "destination": "/assets/$1" }
  ],
  "cleanUrls": true
}
