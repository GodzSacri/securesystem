{
  "rewrites": [
    { "source": "/", "destination": "/templates/login.html" },
    { "source": "/login", "destination": "/templates/login.html" },
    { "source": "/inbox", "destination": "/templates/inbox.html" },
    { "source": "/compose", "destination": "/templates/compose.html" },
    { "source": "/sent", "destination": "/templates/sent.html" },
    { "source": "/admin", "destination": "/templates/admin.html" },
    { "source": "/view_message/:id", "destination": "/templates/viewmessage.html" },
    { "source": "/static/(.*)", "destination": "/static/$1" }
  ],
  "cleanUrls": true
}
