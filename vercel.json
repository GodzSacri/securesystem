{
  "rewrites": [
    {
      "source": "/",
      "destination": "/frontend/templates/login.html"
    },
    {
      "source": "/login",
      "destination": "/frontend/templates/login.html"
    },
    {
      "source": "/inbox",
      "destination": "/frontend/templates/inbox.html"
    },
    {
      "source": "/compose",
      "destination": "/frontend/templates/compose.html"
    },
    {
      "source": "/sent",
      "destination": "/frontend/templates/sent.html"
    },
    {
      "source": "/admin",
      "destination": "/frontend/templates/admin.html"
    },
    {
      "source": "/static/(.*)",
      "destination": "/frontend/static/$1"
    }
  ]
}
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://securesys-backend.onrender.com/api/$1",
      "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET, POST, PUT, DELETE, OPTIONS",
        "Access-Control-Allow-Headers": "Authorization, Content-Type"
      }
    }
  ]
}
