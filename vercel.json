{
  "rewrites": [
    { "source": "/", "destination": "/frontend/login.html" },
    { "source": "/login", "destination": "/frontend/login.html" },
    { "source": "/inbox", "destination": "/frontend/inbox.html" },
    { "source": "/compose", "destination": "/frontend/compose.html" },
    { "source": "/sent", "destination": "/frontend/sent.html" },
    { "source": "/admin", "destination": "/frontend/admin.html" },
    { "source": "/view_message/:id", "destination": "/frontend/view_message.html" },
    { "source": "/css/(.*)", "destination": "/frontend/css/$1" },
    { "source": "/js/(.*)", "destination": "/frontend/js/$1" },
    { "source": "/assets/(.*)", "destination": "/frontend/assets/$1" }
  ]
}
